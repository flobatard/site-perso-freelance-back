# HTTP
PORT=3000

# Origines autorisées pour CORS (séparées par des virgules)
FRONTEND_URL=http://localhost:8081

# Stockage local des soumissions de formulaires (data.json uniquement, les fichiers vont sur S3)
DATA_DIR=data

# Stockage objet S3 (MinIO en local, S3/Scaleway/etc. en prod)
# Pour MinIO local : http://localhost:9000
# Pour AWS S3 : laisser S3_ENDPOINT vide
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=showcase-forms
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
# true requis pour MinIO, false pour AWS S3
S3_FORCE_PATH_STYLE=true

# SMTP (nodemailer)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Adresses pour les notifications
SMTP_FROM=
NOTIFY_TO=
